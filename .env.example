# ====================================================================
# .env.example — Plantilla. Cópialo a .env y rellena.
# NO PONGAS SECRETOS REALES AQUÍ. Este archivo SE SUBE A GIT.
# ====================================================================

ENV=development
LOG_LEVEL=DEBUG
TZ=Europe/Madrid

API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

POSTGRES_DB=avisos
POSTGRES_USER=avisos_user
POSTGRES_PASSWORD=cambia-esto-en-tu-env
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://avisos_user:cambia-esto-en-tu-env@postgres:5432/avisos

REDIS_PASSWORD=cambia-esto-en-tu-env
REDIS_URL=redis://:cambia-esto-en-tu-env@redis:6379/0
CELERY_BROKER_URL=redis://:cambia-esto-en-tu-env@redis:6379/1
CELERY_RESULT_BACKEND=redis://:cambia-esto-en-tu-env@redis:6379/2

MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=cambia-esto-en-tu-env
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=notice-media
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USE_SSL=false

JWT_SECRET_KEY=genera-uno-con-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token_aqui
TWILIO_FROM_NUMBER=+34900000000
TWILIO_OTP_TEMPLATE=Tu código de verificación es: {code}. Caduca en 5 min.

FCM_CREDENTIALS_PATH=/code/secrets/fcm-service-account.json
FCM_PROJECT_ID=avisos-municipales-prod

OTP_MAX_ATTEMPTS_PER_PHONE=3
OTP_WINDOW_MINUTES=10

NOTICE_MAX_IMAGE_MB=10
NOTICE_MAX_VIDEO_MB=100
SMS_FALLBACK_DELAY_SECONDS=60